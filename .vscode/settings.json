{
    "rust-analyzer.linkedProjects": [
        "${workspaceFolder}/rust-project.json",
    ],
    // "rust-analyzer.workspace.discoverConfig": {
    //     // Use absolute path to the script
    //     "command": ["bash", "${workspaceFolder}/discover_bazel_rust_project.sh", "{arg}"],
    //     "progressLabel": "Syncing Rust...",
    //     "filesToWatch": [
    //         "${workspaceFolder}/BUILD.bazel",
    //         "${workspaceFolder}/MODULE.bazel"
    //     ],
    // },
    // Prevent rust-analyzer from trying to index the Bazel symlink forest
    "files.watcherExclude": {
        "**/bazel-out/**": true,
        "**/external/**": true
    },
    "rust-analyzer.files.excludeDirs": [
        "bazel-out",
        "external"
    ],
    "clangd.arguments": [
        "--header-insertion=never",
        "--compile-commands-dir=${workspaceFolder}/",
        "--query-driver=${workspaceFolder}/external/toolchains_llvm*/**/bin/clang*",
        "--background-index"
    ],
    "editor.tabSize": 4,
    "editor.unusualLineTerminators": "auto",
    "files.insertFinalNewline": true,
    "[json]": {
        "editor.quickSuggestions": {
            "strings": true
        },
        "editor.indentSize": "tabSize",
        "editor.suggest.insertMode": "replace"
    },
    "[c]": {
        "editor.indentSize": "tabSize",
        "editor.suggest.insertMode": "replace"
    },
    "clangd.onConfigChanged": "restart",
}
