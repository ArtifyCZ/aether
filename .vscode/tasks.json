{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Sync Project (C + Rust)",
      "type": "shell",
      "command": "python3 discover_bazel_c_compile_commands.py --config=${input:targetArch} && bash discover_bazel_rust_project.sh --bazel_arg=--platforms=//platforms:kernel_${input:targetArch}",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ],
  "inputs": [
    {
      "id": "targetArch",
      "type": "pickString",
      "description": "Which architecture are you targeting?",
      "options": ["x86_64", "aarch64"],
      "default": "x86_64"
    }
  ]
}
