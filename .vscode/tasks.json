{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Sync Project (C + Rust)",
            "type": "shell",
            "command": "make compile_commands.json rust-project.json ARCH=${input:targetArch}",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true,
            },
        },
    ],
    "inputs": [
        {
            "id": "targetArch",
            "type": "pickString",
            "description": "Which architecture are you targeting?",
            "options": ["x86_64", "aarch64"],
            "default": "x86_64",
        },
    ],
}
