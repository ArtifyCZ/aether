{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug kernel in Qemu",
            "type": "lldb-dap",
            "request": "attach",
            "program": "${workspaceFolder}/bazel-bin/kernel/entry/kernel",
            "gdb-remote-port": 1234,
            "gdb-remote-hostname": "127.0.0.1",
        },
        {
            "name": "Debug init in Qemu",
            "type": "lldb-dap",
            "request": "attach",
            "program": "${workspaceFolder}/bazel-bin/init/init",
            "attachCommands": [
                "platform select remote-gdb-server",
                "gdb-remote localhost:1234",
                "target modules load --file ${workspaceFolder}/bazel-bin/init/init --slide 0x55550000",
            ],
        },
        {
            "name": "Debug hello_world in Qemu",
            "type": "lldb-dap",
            "request": "attach",
            "program": "${workspaceFolder}/bazel-bin/hello_world/hello_world",
            "gdb-remote-port": 1234,
            "gdb-remote-hostname": "127.0.0.1",
        },
    ],
}
