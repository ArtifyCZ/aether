include ../common.mk

LDFLAGS :=
LDFLAGS += -nostdlib \
	-static \
	-z max-page-size=0x1000 \
	--no-dynamic-linker \
	--gc-sections
LDFLAGS += -T kernel.$(ARCH).ld

$(KERNEL_MODULE__KERNEL_ELF): $(KERNEL_PLATFORM_MODULE__LIB_KERNEL_PLATFORM_A) $(KERNEL_CORE_MODULE__LIB_KERNEL_CORE_A)
	$(LD) $(LDFLAGS) $(KERNEL_PLATFORM_MODULE__LIB_KERNEL_PLATFORM_A) $(KERNEL_CORE_MODULE__LIB_KERNEL_CORE_A) -o $(KERNEL_MODULE__KERNEL_ELF)
